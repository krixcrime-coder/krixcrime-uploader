# Copy this file to .env.local for local development
# For production (Vercel), set these as Environment Variables in Vercel dashboard

# GitHub Personal Access Token (repo read/write scope)
GH_PAT=ghp_xxxxxxxxxxxxxxxxxxxx

# Your GitHub repo in the format: username/reponame
REPO_NAME=yourusername/your-repo-name

# Dashboard password hash (generate with: python scripts/generate_password_hash.py)
DASHBOARD_PASSWORD_HASH=$2b$10$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Random secret for signing session cookies (use a long random string)
SESSION_SECRET=change-this-to-a-long-random-secret-string-at-least-32-chars

# For local dev only — plain text password fallback (ignored if DASHBOARD_PASSWORD_HASH is set)
# DASHBOARD_PASSWORD=krixcrime2024
